    "sheet.degraded.learn.more.details" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some funds are ready for the most private send flow, while others still need an extra privacy step.\n\nYou can still send them now, and the payment will work normally. However, those funds may reveal a little more information on-chain than funds that are fully ready for private sending.\n\nFor the strongest privacy, send only the private-ready amount or wait until the rest of your funds are ready.\n"
          }
        }
      }
    },
    "sheet.degraded.learn.more.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why are some funds less private?"
          }
        }
      }
    },
    "sheet.degraded.message.full" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To send the full %1$(full)@, some funds will use lower-privacy sources."
          }
        }
      }
    },
    "sheet.degraded.message.with.degraded" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can send %1$(nonDegraded)@ privately.\n\nTo send the full %2$(full)@, the remaining %3$(degraded)@ will use lower-privacy funds."
          }
        }
      }
    },
