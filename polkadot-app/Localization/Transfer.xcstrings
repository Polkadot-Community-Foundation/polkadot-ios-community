{
  "sourceLanguage" : "en",
  "strings" : {
    "balance.info.available.now.info.section1.detail1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is the amount you can use for a payment right away."
          }
        }
      }
    },
    "balance.info.available.now.info.section1.detail2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It may include funds that are already ready for private sending, funds that can be prepared instantly for a payment, and funds that can be sent now with slightly less privacy."
          }
        }
      }
    },
    "balance.info.available.now.info.section1.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What does “Available now” mean?"
          }
        }
      }
    },
    "balance.info.available.now.info.section2.detail1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Some funds are ready to send, but have not completed all privacy preparation steps yet. If you use them now, they may reveal a little more on-chain information than fully private funds."
          }
        }
      }
    },
    "balance.info.available.now.info.section2.detail2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To make them private, you don’t need to do anything. Just wait — they will become private-ready automatically."
          }
        }
      }
    },
    "balance.info.available.now.info.section2.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Why are some funds less private?"
          }
        }
      }
    },
    "balance.info.available.soon.info.detail1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These funds are still being made private and cannot be sent yet."
          }
        }
      }
    },
    "balance.info.available.soon.info.detail2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "They may include funds from recent payments that are still settling, or change that is being made ready for future private sends."
          }
        }
      }
    },
    "balance.info.available.soon.info.detail3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "They will become available automatically once processing is complete. Usually takes around 1-5 minutes."
          }
        }
      }
    },
    "balance.info.available.soon.info.title" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "What does “Available soon” mean?"
          }
        }
      }
    },
