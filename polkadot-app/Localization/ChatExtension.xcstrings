    },
    "dim1.welcome1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Become a Member by Getting a Unique Free Tattoo**\n\n✍️ Get Inked with Any Artist You Like and Provide a 3 Minute Video Documenting the Tattoo Process"
          }
        }
      }
    },
    "dim1.welcome2" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📐 **Size.** This tattoo is available in several sizes ranging from 25 to 50 millimeters. You will see stencil with all sizes after booking.\n\n💪 **Tattoo Location.** The tattoo has to be made on inner part of the upper left arm. Centred between armpit and elbow."
          }
        }
      }
    },
    "dim1.welcome3" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🎨 **Design.** Add a small $10 deposit to select your unique design from over 2,000 options available."
          }
        }
      }
    },
    "dim1.welcome4" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📆 **Execution.** Find any tattooer you like. You will also see a few suggested tattoo studios after booking."
          }
        }
      }
    },
    "dim1.welcome5" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🤳 **Evidence.** Provide 3-minute proof of documentation video and a picture of the final tattoo"
          }
        }
      }
    },
    "dim1.welcome6" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🗳️ **Review.** Tattoo Evidence is reviewed by other Polkadot peers, who will vote individually based on your documentation video evidence.\n\n💸 **Reimbursement.** Get Your Tattoo Expenses Refund"
          }
        }
      }
    },
