      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "💸  Don't forget, tattoo expenses will be reimbursed, so go ahead and spend your funds; you'll get them back once your evidence is approved."
          }
        }
      }
    },
    "message.commit.evidence.instructions" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "**Provide Photo and Video Documentation**\n\n🤳 Film the process while getting a tattoo. You can either ask for assistance or use the in-app camera to film yourself.\n🎦 Begin filming once the majority of the tattoo has been completed, ensuring that the chosen design is clearly visible.\n⏱️ Film closer moments when making tattoo lines over the stencil image\n🔄 Film 3 minute video without breaks\n📸 Take a picture of the fresh tattoo exposed"
          }
        }
      }
    },
    "message.commit.evidence.video" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "🎦 Evidence 1 \/ 2. The documentation video comes first. Press the \"provide\" button when you're at the tattoo studio and ready to start filming with the in-app camera."
          }
        }
      }
    },
